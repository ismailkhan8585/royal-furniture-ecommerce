generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  OFFICE
  LIVING_ROOM
  BEDROOM
  DINING
  STUDY_KIDS
  OUTDOOR
  CUSTOM

  @@map("category")
}

enum PriceType {
  FIXED
  INQUIRY

  @@map("price_type")
}

enum StockType {
  IN_STOCK
  MADE_TO_ORDER
  OUT_OF_STOCK

  @@map("stock_type")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED

  @@map("order_status")
}

enum PaymentMethod {
  COD
  JAZZCASH
  EASYPAISA
  BANK_TRANSFER

  @@map("payment_method")
}

enum PaymentStatus {
  UNPAID
  PAID
  PARTIAL
  REFUNDED

  @@map("payment_status")
}

enum CustomRequestStatus {
  PENDING
  QUOTED
  APPROVED
  IN_PRODUCTION
  READY
  DELIVERED
  CANCELLED

  @@map("custom_request_status")
}

model Admin {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String    @unique
  password       String
  name           String
  is_active      Boolean   @default(true)
  last_login_at  DateTime? @db.Timestamptz(6)
  login_attempts Int       @default(0)
  locked_until   DateTime? @db.Timestamptz(6)
  created_at     DateTime  @default(now()) @db.Timestamptz(6)
  updated_at     DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("admins")
}

model Product {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug             String      @unique
  name             String
  name_urdu        String?
  category         Category    @default(LIVING_ROOM)
  sub_category     String?
  material         String?
  dimensions       String?
  color            String?
  description      String?
  description_urdu String?
  photos           String[]    @default([])
  price_type       PriceType   @default(FIXED)
  price            Decimal?    @db.Decimal(12, 2)
  compare_price    Decimal?    @db.Decimal(12, 2)
  stock            Int         @default(0)
  stock_type       StockType   @default(IN_STOCK)
  sku              String?     @unique
  featured         Boolean     @default(false)
  is_active        Boolean     @default(true)
  warranty         String?
  tags             String[]    @default([])
  rating           Decimal     @default(0) @db.Decimal(3, 2)
  review_count     Int         @default(0)
  created_at       DateTime    @default(now()) @db.Timestamptz(6)
  updated_at       DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  order_items      OrderItem[]
  reviews          Review[]

  @@index([category])
  @@index([featured])
  @@index([is_active])
  @@index([slug])
  @@map("products")
}

model Order {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_number       String        @unique
  customer_name      String
  customer_phone     String
  customer_email     String?
  address            String
  city               String
  area               String?
  delivery_fee       Decimal       @db.Decimal(10, 2)
  subtotal           Decimal       @db.Decimal(12, 2)
  total_amount       Decimal       @db.Decimal(12, 2)
  payment_method     PaymentMethod
  payment_screenshot String?
  payment_status     PaymentStatus @default(UNPAID)
  status             OrderStatus   @default(PENDING)
  notes              String?
  invoice_url        String?
  estimated_delivery DateTime?     @db.Date
  delivered_at       DateTime?     @db.Timestamptz(6)
  created_at         DateTime      @default(now()) @db.Timestamptz(6)
  updated_at         DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  items              OrderItem[]

  @@index([order_number, customer_phone])
  @@index([status])
  @@index([created_at])
  @@map("orders")
}

model OrderItem {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id      String   @db.Uuid
  product_id    String?  @db.Uuid
  product_name  String
  product_photo String?
  quantity      Int
  unit_price    Decimal  @db.Decimal(12, 2)
  total_price   Decimal  @db.Decimal(12, 2)
  order         Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product       Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)

  @@index([order_id])
  @@index([product_id])
  @@map("order_items")
}

model CustomOrderRequest {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  request_ref      String              @unique
  furniture_type   String
  room_type        String?
  material         String?
  budget_range     String?
  dimensions       String?
  description      String?
  reference_images String[]            @default([])
  customer_name    String
  customer_phone   String
  city             String
  status           CustomRequestStatus @default(PENDING)
  quoted_price     Decimal?            @db.Decimal(12, 2)
  notes            String?
  created_at       DateTime            @default(now()) @db.Timestamptz(6)
  updated_at       DateTime            @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([status])
  @@map("custom_order_requests")
}

model Review {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id     String   @db.Uuid
  customer_name  String
  customer_phone String
  rating         Int
  body           String
  is_approved    Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  product        Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([is_approved])
  @@map("reviews")
}

model GalleryImage {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  image_url  String
  category   Category?
  caption    String?
  sort_order Int       @default(0)
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  @@index([sort_order])
  @@map("gallery_images")
}

model SiteSettings {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  store_name        String   @default("Royal Furniture")
  tagline_en        String?  @default("Comfort Meets Class")
  phone             String
  whatsapp          String
  jazzcash_number   String?
  easypaisa_number  String?
  bank_iban         String?
  email             String
  address           String
  facebook_url      String?
  instagram_url     String?
  tiktok_url        String?
  free_delivery_min Decimal  @default(50000) @db.Decimal(10, 2)
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("site_settings")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
