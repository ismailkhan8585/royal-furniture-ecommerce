# Royal Furniture Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# DATABASE (Supabase - Pre-configured)
# ===========================================
# These are already configured in the hosted environment
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ===========================================
# NEXTAUTH (Admin Authentication)
# ===========================================
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ===========================================
# CLOUDINARY (Image Storage)
# ===========================================
# Sign up at cloudinary.com and get your credentials
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# ===========================================
# APP SETTINGS
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Royal Furniture

# ===========================================
# CONTACT INFORMATION
# ===========================================
# Pakistani phone format: 923XXXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=923001234567
NEXT_PUBLIC_PHONE_NUMBER=+923001234567
NEXT_PUBLIC_EMAIL=info@royalfurniture.pk
NEXT_PUBLIC_ADDRESS=123 Furniture Street, Lahore, Pakistan

# ===========================================
# PAYMENT INFORMATION
# ===========================================
# JazzCash and EasyPaisa business numbers
NEXT_PUBLIC_JAZZCASH_NUMBER=0300-1234567
NEXT_PUBLIC_EASYPAISA_NUMBER=0300-1234567
NEXT_PUBLIC_BANK_IBAN=PK00BANK0000000000000000

# ===========================================
# SOCIAL MEDIA URLS
# ===========================================
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/royalfurniturepk
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/royalfurniturepk
NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@royalfurniturepk

# ===========================================
# EMAIL (Resend)
# ===========================================
# Sign up at resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# ===========================================
# SMS (Twilio) - Optional
# ===========================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===========================================
# ADMIN SEED (Initial Admin User)
# ===========================================
# Used only during initial seeding
ADMIN_SEED_EMAIL=admin@royalfurniture.pk
ADMIN_SEED_PASSWORD=secure-password-here
